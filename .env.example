# Base model runner. runner/localModelU.sh overrides this to llamaLocal for
# local Ubuntu runs with an already installed llama-server.
BASE_MODEL_RUNNER_TYPE=llama16GB

# Hugging Face token with access to gaia-benchmark/GAIA.
HF_TOKEN=hf_change_me

# GAIA task and dataset parameters.
# Common task values: inspect_evals/gaia, inspect_evals/gaia_level1,
# inspect_evals/gaia_level2, inspect_evals/gaia_level3.
# Level 1 is the practical default for smaller models.
GAIA_TASK=inspect_evals/gaia_level1
GAIA_SPLIT=validation

# Inclusive Inspect sample range passed as --limit START-END.
# Leave both empty to evaluate the entire split.
GAIA_SAMPLE_START=
GAIA_SAMPLE_END=

# Runtime controls.
GAIA_MAX_CONNECTIONS=1
# Leave empty to let Inspect choose its default sample parallelism.
GAIA_MAX_SAMPLES=

GAIA_MAX_ATTEMPTS=1
GAIA_SANDBOX=local

SCAFFOLD_PORT=19080
SCAFFOLD_API_KEY=local
SCAFFOLD_MODEL_NAME=gaia-scaffold-bon

SCAFFOLD_BON_CANDIDATES=1

GAIA_MODEL_BASE_URL="http://127.0.0.1:${SCAFFOLD_PORT}/v1"
GAIA_MODEL_API_KEY=${SCAFFOLD_API_KEY}
GAIA_MODEL_NAME=${SCAFFOLD_MODEL_NAME}

FEATURE_EXAMPLE=0
FEATURE_BUDGET_TRACKER=0
FEATURE_VOI=0
FEATURE_SELF_CONSISTENCY=0
FEATURE_SHORT_MAK=0
FEATURE_ACON=0
FEATURE_ADAPTIVE_BON=0
FEATURE_CATTS=0
FEATURE_BAVT=0
FEATURE_RANKED_VOTING=0
FEATURE_PICSAR=0
FEATURE_MOB=0
FEATURE_STRUCTURED_NOTES=0
FEATURE_RESUM=0
FEATURE_HIAGENT=0
FEATURE_CONTEXT_COMPACTION=0
FEATURE_COMPLEXITY_CONSISTENCY=0
FEATURE_LLM_JUDGE=0

# Local Ubuntu/offline runner (runner/local_start.sh).
# Use absolute paths on the machine that runs the benchmark.
LOCAL_MODEL_PATH=
GAIA_DATASET_DIR=
LOCAL_LLAMA_SERVER=

# Compatibility variables for the checked-in Ubuntu runner:
#   sh runner/localModelU.sh
# They may be used instead of the LOCAL_* names above.
LLAMA_SERVER_BIN=
LLAMA_SERVER_PORT=18082
LLAMA_CTX_SIZE=262144
LLAMA_PARALLEL=1
LLAMA_THREADS=4
LLAMA_N_GPU_LAYERS=999
LLAMA_BATCH_SIZE=512
LLAMA_UBATCH_SIZE=128
LLAMA_JINJA=auto
LLAMA_USE_EXISTING_SERVER=0

# Keep local 127.0.0.1 model/scaffold calls away from broken proxy settings.
INSPECT_DISABLE_PROXY=1
GAIA_CHECK_DATASET_CACHE=1

# Optional: force a Python executable. If empty, local_start.sh prefers the
# active conda environment and then falls back to .venv.
LOCAL_PYTHON=

LOCAL_MODEL_HOST=127.0.0.1
LOCAL_MODEL_PORT=18082
LOCAL_MODEL_CONTEXT=262144
LOCAL_MODEL_GPU_LAYERS=999
LOCAL_MODEL_THREADS=4
LOCAL_MODEL_PARALLEL=1
LOCAL_MODEL_BATCH_SIZE=512
LOCAL_MODEL_UBATCH_SIZE=128
LOCAL_MODEL_START_TIMEOUT=900

# Match the Colab runner setup when Chromium is missing. Keep 0 for fully
# offline benchmark runs after Playwright Chromium has already been installed.
LOCAL_PLAYWRIGHT_INSTALL=0
LOCAL_TOOL_SUPPORT_POST_INSTALL=1

# Upper bound for one request from scaffold to llama-server, in seconds.
BASE_MODEL_REQUEST_TIMEOUT=1800

# Upper bound for the complete `inspect eval` process. Set to 0 to disable.
GAIA_RUN_TIMEOUT=7200
# Optional Inspect CLI message limit. Leave empty to use the task default.
GAIA_MESSAGE_LIMIT=

# Baseline is the default. To enable exactly one technique, set its complete
# environment variable name, e.g. GAIA_FEATURE=FEATURE_CATTS.
GAIA_FEATURE=
