# Hugging Face token with access to gaia-benchmark/GAIA.
HF_TOKEN=hf_change_me

# GAIA task and dataset parameters.
# Common task values: inspect_evals/gaia, inspect_evals/gaia_level1,
# inspect_evals/gaia_level2, inspect_evals/gaia_level3.
# Level 1 is the practical default for smaller models.
GAIA_TASK=inspect_evals/gaia_level1
GAIA_SPLIT=validation

# Inclusive Inspect sample range passed as --limit START-END.
# Leave both empty to evaluate the entire split.
GAIA_SAMPLE_START=
GAIA_SAMPLE_END=

# Runtime controls.
GAIA_MAX_CONNECTIONS=1
# Leave empty to let Inspect choose its default sample parallelism.
GAIA_MAX_SAMPLES=

GAIA_MAX_ATTEMPTS=1
GAIA_SANDBOX=local

SCAFFOLD_PORT=19080
SCAFFOLD_API_KEY=local
SCAFFOLD_MODEL_NAME=gaia-scaffold-bon

SCAFFOLD_BON_CANDIDATES=1

GAIA_MODEL_BASE_URL="http://127.0.0.1:${SCAFFOLD_PORT}/v1"
GAIA_MODEL_API_KEY=${SCAFFOLD_API_KEY}
GAIA_MODEL_NAME=${SCAFFOLD_MODEL_NAME}

# Demo middleware changes model responses and must stay off for a clean benchmark.
FEATURE_EXAMPLE=0

CATTS_ENABLED=0
CATTS_N_SAMPLES=3
CATTS_ENTROPY_THRESHOLD=0.9
